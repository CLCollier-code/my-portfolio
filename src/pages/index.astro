---
// src/pages/index.astro — your homepage

import Layout from "../layouts/Layout.astro";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";

const blocks = [
  {
    type: "hero",
    heading: "Chris Collier",
    subheading: "IT Systems & Infrastructure",
    summary:
      "Detail-oriented IT professional and recent graduate with hands-on experience in web development, systems administration, and network fundamentals. Thrives in back-of-house, internal IT environments where technical ownership and problem-solving take center stage. Proficient across Windows, macOS, Linux, iOS, and Android platforms.",
    ctaLabel: "View Projects",
    ctaHref: "/projects",
  },
  {
    type: "skillsGrid",
    heading: "Skills",
    skills: [
      {
        category: "Languages",
        items: ["HTML", "CSS", "JavaScript", "SQL", "Java", "Python"],
      },
      {
        category: "Operating Systems",
        items: ["Windows", "macOS", "Linux", "Android", "iOS"],
      },
      {
        category: "Networking",
        items: ["TCP/IP", "HTTP", "DNS", "Routers", "Switches", "Firewalls"],
      },
      {
        category: "Productivity",
        items: [
          "Word",
          "Excel",
          "Access",
          "Teams",
          "PowerPoint",
          "OneNote",
          "Outlook",
          "Google Workspace",
        ],
      },
      {
        category: "Web & DevOps",
        items: [
          "Eleventy",
          "Astro",
          "Bootstrap",
          "Sveltia CMS",
          "Cloudflare",
          "Vercel",
          "Netlify",
          "GitHub",
          "JAMstack",
          "CI/CD",
          "MySQL",
        ],
      },
      {
        category: "Accessibility",
        items: ["WCAG", "Resend", "Navigate360"],
      },
    ],
  },
  {
    type: "projectCard",
    heading: "Projects",
    projects: [
      {
        title: "JAMstack Website Redesign — Local Counseling Practice",
        description:
          "Led architecture, design, and development of a full JAMstack site for a live local client. Built a headless CMS with 15+ modular content blocks so non-technical staff can manage all content without touching code. Implemented per-counselor contact form routing with Cloudflare Turnstile spam filtering and a GitHub-based CI/CD publishing pipeline. Delivered a WCAG-accessible, brand-aligned platform at zero hosting cost.",
        tags: [
          "Eleventy",
          "Bootstrap",
          "Sveltia CMS",
          "Cloudflare",
          "JAMstack",
          "CI/CD",
          "WCAG",
        ],
        githubUrl: "",
        liveUrl: "https://lynchburg-site.emcitconsultants.workers.dev",
      },
    ],
  },
  {
    type: "certBadge",
    heading: "Education & Certifications",
    certs: [
      {
        name: "Associate of Applied Science — Information Systems Technology",
        issuer: "Central Virginia Community College",
        year: "May 2026",
      },
      {
        name: "Career Studies Certificate — Information Systems Technology Fundamentals",
        issuer: "Central Virginia Community College",
        year: "2026",
      },
      {
        name: "Career Studies Certificate — Information Systems Technology Plus",
        issuer: "Central Virginia Community College",
        year: "2026",
      },
    ],
  },
  {
    type: "contact",
    heading: "Get In Touch",
    subheading:
      "Open to back-of-house IT roles in the Lynchburg, VA area. Feel free to connect on LinkedIn or browse my work on GitHub.",
    linkedinUrl: "https://www.linkedin.com/in/chris-collier-tech/",
    githubUrl: "https://github.com/CLCollier-code",
    resumeUrl: "/resume.pdf",
  },
];
---

<Layout title="Home">
  {blocks.map((block) => <BlockRenderer block={block} />)}
</Layout>
