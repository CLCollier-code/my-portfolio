---
// src/pages/index.astro — your homepage
//
// This is the modular page pattern.
// In production, 'blocks' will come from Sveltia via Content Collections.
// For now it's hardcoded so you can see the structure working immediately.

import Layout from "../layouts/Layout.astro";
import BlockRenderer from "../components/ui/blocks/BlockRenderer.astro";

const blocks = [
  {
    type: "hero",
    heading: "Chris Collier",
    subheading: "IT Systems & Infrastructure",
    summary:
      "Detail-oriented IT professional and recent graduate with hands-on experience in web development, systems administration, and network fundamentals. Thrives in back-of-house, internal IT environments where technical ownership and problem-solving take center stage.",
    ctaLabel: "View Projects",
    ctaHref: "#projects",
  },
  {
    type: "skillsGrid",
    heading: "Skills",
    skills: [
      {
        category: "Languages",
        items: ["HTML", "CSS", "JavaScript", "Python"],
      },
      {
        category: "Operating Systems",
        items: ["Windows", "macOS", "Linux (Ubuntu)", "Linux (Mint)"],
      },
      {
        category: "Networking",
        items: ["TCP/IP", "HTTP", "DNS", "Routers", "Switches", "Firewalls"],
      },
      {
        category: "Productivity",
        items: ["Microsoft 365", "Microsoft Teams", "Google Workspace"],
      },
      {
        category: "Web & DevOps",
        items: [
          "Eleventy",
          "Astro",
          "Bootstrap",
          "Sveltia CMS",
          "Cloudflare",
          "GitHub",
          "JAMstack",
          "CI/CD",
        ],
      },
      {
        category: "Accessibility",
        items: ["WCAG", "Navigate360", "Resend"],
      },
    ],
  },
  {
    type: "projectCard",
    heading: "Projects",
    projects: [
      {
        title: "JAMstack Website Redesign — Local Counseling Practice",
        description:
          "Led architecture, design, and development of a full JAMstack site for a live local client. Built a headless CMS with 15+ modular content blocks so non-technical staff can manage all content without touching code. Implemented per-counselor contact form routing with Cloudflare Turnstile spam filtering and a GitHub-based CI/CD publishing pipeline. Delivered a WCAG-accessible, brand-aligned platform at zero hosting cost.",
        tags: [
          "Eleventy",
          "Bootstrap",
          "Sveltia CMS",
          "Cloudflare",
          "JAMstack",
          "CI/CD",
          "WCAG",
        ],
        githubUrl: "https://github.com/GCGroup-LYH/lynchburg-site.git",
        liveUrl: "https://your-live-site-url.com",
      },
    ],
  },
  {
    type: "certBadge",
    heading: "Education & Certifications",
    certs: [
      {
        name: "Associate of Applied Science — Information Systems Technology",
        issuer: "Central Virginia Community College",
        year: "May 2026",
      },
      {
        name: "Career Studies Certificate — Information Systems Technology Fundamentals",
        issuer: "Central Virginia Community College",
        year: "2026",
      },
      {
        name: "Career Studies Certificate — Information Systems Technology Plus",
        issuer: "Central Virginia Community College",
        year: "2026",
      },
    ],
  },
];
---

<Layout title="Home">
  {blocks.map((block) => <BlockRenderer block={block} />)}
</Layout>
