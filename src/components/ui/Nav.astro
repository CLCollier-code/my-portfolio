---
// Nav.astro — shared navigation
// Lives in src/components/ui/Nav.astro

const currentPath = Astro.url.pathname;
---

<header>
  <nav
    class="navbar navbar-expand-lg bg-body-tertiary border-bottom"
    aria-label="Main navigation"
  >
    <div class="container">
      <!-- Brand -->
      <a
        class="navbar-brand fw-semibold"
        href="/"
        aria-label="Chris Collier — IT Portfolio home"
      >
        Chris Collier
        <span class="text-muted fw-normal fs-6 ms-1" aria-hidden="true"
          >IT Portfolio</span
        >
      </a>

      <!-- Mobile toggle -->
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#mainNav"
        aria-controls="mainNav"
        aria-expanded="false"
        aria-label="Toggle navigation menu"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Nav links -->
      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a
              class={`nav-link ${currentPath === "/" ? "active" : ""}`}
              aria-current={currentPath === "/" ? "page" : undefined}
              href="/">Home</a
            >
          </li>

          <li class="nav-item">
            <a
              class={`nav-link ${currentPath === "/projects" ? "active" : ""}`}
              aria-current={currentPath === "/projects" ? "page" : undefined}
              href="/projects">Projects</a
            >
          </li>

          <li class="nav-item">
            <a
              class={`nav-link ${currentPath === "/education" ? "active" : ""}`}
              aria-current={currentPath === "/education" ? "page" : undefined}
              href="/education">Education</a
            >
          </li>

          <li class="nav-item">
            <a
              class={`nav-link ${currentPath === "/resume" ? "active" : ""}`}
              aria-current={currentPath === "/resume" ? "page" : undefined}
              href="/resume">Resume</a
            >
          </li>

          <!-- LinkedIn -->
          <li class="nav-item ms-lg-2">
            <a
              href="https://www.linkedin.com/in/chris-collier-tech/"
              target="_blank"
              rel="noopener"
              class="btn btn-outline-primary btn-sm"
              aria-label="LinkedIn profile (opens in new tab)"
              >LinkedIn <span aria-hidden="true">↗</span></a
            >
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>
