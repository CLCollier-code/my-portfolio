---
// Nav.astro — shared navigation
// Lives in src/components/ui/Nav.astro
// Uses anchor links for single-page navigation for now.
// Can be updated to full page links once /about and /projects pages are built.
---

<header>
  <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
    <div class="container">
      <!-- Brand -->
      <a class="navbar-brand fw-semibold" href="/">
        Chris Collier
        <span class="text-muted fw-normal fs-6 ms-1">IT Portfolio</span>
      </a>

      <!-- Mobile toggle -->
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#mainNav"
        aria-controls="mainNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Nav links -->
      <div class="collapse navbar-collapse" id="mainNav">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" href="#skills">Skills</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="#projects">Projects</a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="#certifications">Education</a>
          </li>

          <!-- Resume opens as PDF in a new tab -->
          <li class="nav-item ms-lg-2">
            <a
              class="btn btn-outline-primary btn-sm"
              href="/resume.pdf"
              target="_blank"
              rel="noopener">Resume ↗</a
            >
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>
