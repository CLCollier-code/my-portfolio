---
// Footer.astro — shared footer
// Lives in src/components/ui/Footer.astro

const year = new Date().getFullYear();
---

<footer class="border-top bg-body-tertiary mt-auto py-4">
  <div
    class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-2"
  >
    <p class="mb-0 text-muted small">
      &copy; {year} Christopher L. Collier. Built with Astro &amp; Bootstrap.
    </p>

    <nav aria-label="Footer navigation">
      <ul class="list-inline mb-0 small">
        <li class="list-inline-item">
          <a href="/privacy" class="text-muted text-decoration-none">Privacy</a>
        </li>
        <li class="list-inline-item ms-2">
          <a href="/accessibility" class="text-muted text-decoration-none"
            >Accessibility</a
          >
        </li>
        <li class="list-inline-item ms-2">
          <a
            href="https://github.com/CLCollier-code"
            target="_blank"
            rel="noopener"
            class="text-muted text-decoration-none"
            aria-label="GitHub profile (opens in new tab)">GitHub ↗</a
          >
        </li>
        <li class="list-inline-item ms-2">
          <a
            href="https://www.linkedin.com/in/chris-collier-tech/"
            target="_blank"
            rel="noopener"
            class="text-muted text-decoration-none"
            aria-label="LinkedIn profile (opens in new tab)">LinkedIn ↗</a
          >
        </li>
      </ul>
    </nav>
  </div>
</footer>
