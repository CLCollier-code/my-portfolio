---
// Contact.astro
// Lives in src/components/blocks/Contact.astro
// Displays LinkedIn, GitHub, and resume PDF links.
// Used on the homepage as the final section.

interface Props {
  data: {
    heading: string;
    subheading: string;
    linkedinUrl: string;
    githubUrl: string;
    resumeUrl: string;
  };
}

const { data } = Astro.props;
const { heading, subheading, linkedinUrl, githubUrl, resumeUrl } = data;
---

<section class="contact py-5" id="contact">
  <div class="container">
    <!-- Section header -->
    <div class="section-header mb-5">
      <p class="prompt mb-1">
        <span class="prompt-user">chris@portfolio</span><span class="prompt-sep"
          >:</span
        ><span class="prompt-path">~</span><span class="prompt-sep">$</span>
        <span class="prompt-cmd"> cat ./contact.txt</span>
      </p>
      <h2 class="fw-bold">{heading}</h2>
      <div class="header-line"></div>
      <p class="subheading mt-3">{subheading}</p>
    </div>

    <!-- Links -->
    <div class="row g-4 justify-content-center">
      <!-- LinkedIn -->
      <div class="col-sm-6 col-lg-4">
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener"
          class="contact-card"
        >
          <div class="contact-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              fill="currentColor"
              viewBox="0 0 16 16"
              aria-hidden="true"
            >
              <path
                d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"
              ></path>
            </svg>
          </div>
          <div class="contact-info">
            <p class="contact-label">LinkedIn</p>
            <p class="contact-value">chris-collier-tech</p>
          </div>
          <span class="contact-arrow">↗</span>
        </a>
      </div>

      <!-- GitHub -->
      <div class="col-sm-6 col-lg-4">
        <a href={githubUrl} target="_blank" rel="noopener" class="contact-card">
          <div class="contact-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              fill="currentColor"
              viewBox="0 0 16 16"
              aria-hidden="true"
            >
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path>
            </svg>
          </div>
          <div class="contact-info">
            <p class="contact-label">GitHub</p>
            <p class="contact-value">CLCollier-code</p>
          </div>
          <span class="contact-arrow">↗</span>
        </a>
      </div>

      <!-- Resume -->
      <div class="col-sm-6 col-lg-4">
        <a
          href={resumeUrl}
          target="_blank"
          rel="noopener"
          class="contact-card contact-card-resume"
        >
          <div class="contact-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
              ></path>
            </svg>
          </div>
          <div class="contact-info">
            <p class="contact-label">Resume</p>
            <p class="contact-value">Download PDF</p>
          </div>
          <span class="contact-arrow">↓</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background-color: #0f1117;
    color: #e2e8f0;
    border-top: 1px solid #1e2533;
  }

  /* Section header */
  .section-header h2 {
    font-size: 2rem;
    color: #ffffff;
    margin-bottom: 8px;
  }

  .header-line {
    width: 48px;
    height: 3px;
    background: #68d391;
    border-radius: 2px;
    margin-top: 8px;
  }

  .subheading {
    color: #a0aec0;
    font-size: 1rem;
    max-width: 480px;
  }

  /* Prompt line */
  .prompt {
    font-family: "Courier New", Courier, monospace;
    font-size: 0.85rem;
  }
  .prompt-user {
    color: #68d391;
  }
  .prompt-sep {
    color: #a0aec0;
  }
  .prompt-path {
    color: #63b3ed;
  }
  .prompt-cmd {
    color: #e2e8f0;
  }

  /* Contact card */
  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: #1a1f2e;
    border: 1px solid #2d3748;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: #e2e8f0;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
    width: 100%;
  }

  .contact-card:hover {
    border-color: #68d391;
    transform: translateY(-3px);
    color: #e2e8f0;
  }

  .contact-card-resume:hover {
    border-color: #90cdf4;
  }

  .contact-icon {
    color: #68d391;
    flex-shrink: 0;
  }

  .contact-card-resume .contact-icon {
    color: #90cdf4;
  }

  .contact-info {
    flex: 1;
  }

  .contact-label {
    font-family: "Courier New", Courier, monospace;
    font-size: 0.75rem;
    color: #4a5568;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-value {
    font-size: 0.95rem;
    font-weight: 500;
    color: #e2e8f0;
    margin: 0;
  }

  .contact-arrow {
    font-size: 1.1rem;
    color: #4a5568;
    transition: color 0.2s ease;
  }

  .contact-card:hover .contact-arrow {
    color: #68d391;
  }

  .contact-card-resume:hover .contact-arrow {
    color: #90cdf4;
  }
</style>
