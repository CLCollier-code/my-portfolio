---
// Hero.astro
// Lives in src/components/blocks/Hero.astro
// Terminal/code aesthetic with a professional, approachable tone.

const { data } = Astro.props;
const { heading, subheading, summary, ctaLabel, ctaHref } = data;
---

<section class="hero py-5">
  <div class="container">
    <div class="row align-items-center min-vh-75">
      <div class="col-lg-8">
        <!-- Terminal prompt line -->
        <p class="prompt mb-2">
          <span class="prompt-user">chris@portfolio</span><span
            class="prompt-sep">:</span
          ><span class="prompt-path">~</span><span class="prompt-sep">$</span>
          <span class="prompt-cmd"> whoami</span>
        </p>

        <!-- Name -->
        <h1 class="display-3 fw-bold name mb-1">
          {heading}
        </h1>

        <!-- Role -->
        <p class="role mb-4">
          <span class="role-bracket">[</span>
          {subheading}
          <span class="role-bracket">]</span>
        </p>

        <!-- Summary -->
        <p class="summary lead mb-4">{summary}</p>

        <!-- CTAs -->
        <div class="d-flex gap-3 flex-wrap">
          <a href={ctaHref} class="btn btn-primary btn-lg px-4">
            {ctaLabel}
          </a>
          <a
            href="/resume.pdf"
            target="_blank"
            rel="noopener"
            class="btn btn-outline-secondary btn-lg px-4"
          >
            Resume <span class="ms-1 small">↗</span>
          </a>
        </div>
      </div>

      <!-- Terminal card -->
      <div class="col-lg-4 mt-5 mt-lg-0">
        <div class="terminal">
          <div class="terminal-bar">
            <span class="dot dot-red"></span>
            <span class="dot dot-yellow"></span>
            <span class="dot dot-green"></span>
            <span class="terminal-title">status.sh</span>
          </div>
          <div class="terminal-body">
            <p>
              <span class="t-dim">$</span>
              <span class="t-cmd">cat status.txt</span>
            </p>
            <p>
              <span class="t-key">name</span>
              <span class="t-val">Chris Collier</span>
            </p>
            <p>
              <span class="t-key">status</span>
              <span class="t-green">available</span>
            </p>
            <p>
              <span class="t-key">focus</span>
              <span class="t-val">IT Infrastructure</span>
            </p>
            <p>
              <span class="t-key">certs</span>
              <span class="t-val">CVCC IT Fund. + Adv.</span>
            </p>
            <p>
              <span class="t-key">location</span>
              <span class="t-val">Lynchburg, VA</span>
            </p>
            <p class="mt-2">
              <span class="t-dim">$</span>
              <span class="t-cursor">▋</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: #0f1117;
    color: #e2e8f0;
    border-bottom: 1px solid #1e2533;
  }

  .min-vh-75 {
    min-height: 75vh;
  }

  /* Prompt line */
  .prompt {
    font-family: "Courier New", Courier, monospace;
    font-size: 0.95rem;
  }
  .prompt-user {
    color: #68d391;
  }
  .prompt-sep {
    color: #a0aec0;
  }
  .prompt-path {
    color: #63b3ed;
  }
  .prompt-cmd {
    color: #e2e8f0;
  }

  /* Name */
  .name {
    color: #ffffff;
    letter-spacing: -1px;
    line-height: 1.1;
  }

  /* Role */
  .role {
    font-family: "Courier New", Courier, monospace;
    font-size: 1.1rem;
    color: #a0aec0;
  }
  .role-bracket {
    color: #68d391;
  }

  /* Summary */
  .summary {
    color: #a0aec0;
    max-width: 560px;
    line-height: 1.7;
  }

  /* Terminal card */
  .terminal {
    background: #1a1f2e;
    border: 1px solid #2d3748;
    border-radius: 10px;
    overflow: hidden;
    font-family: "Courier New", Courier, monospace;
    font-size: 0.85rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .terminal-bar {
    background: #2d3748;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-red {
    background: #fc8181;
  }
  .dot-yellow {
    background: #f6e05e;
  }
  .dot-green {
    background: #68d391;
  }

  .terminal-title {
    margin-left: auto;
    color: #718096;
    font-size: 0.75rem;
  }

  .terminal-body {
    padding: 16px 20px;
    line-height: 2;
  }
  .terminal-body p {
    margin: 0;
  }

  .t-dim {
    color: #4a5568;
  }
  .t-cmd {
    color: #90cdf4;
  }
  .t-key {
    color: #68d391;
    display: inline-block;
    width: 90px;
  }
  .t-val {
    color: #e2e8f0;
  }
  .t-green {
    color: #68d391;
  }

  .t-cursor {
    display: inline-block;
    animation: blink 1s step-end infinite;
    color: #68d391;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
</style>
